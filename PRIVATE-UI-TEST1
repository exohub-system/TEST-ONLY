--  LOAD LUCIDE ICONS (same as WindUI uses)
-- ══════════════════════════════════════
local Lucide = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/latte-soft/lucide-roblox/master/dist/lucide-roblox.lua"
))()

local function getIcon(name)
    local ok, asset = pcall(function()
        return Lucide.GetAsset(name, 48)
    end)
    if ok and asset then
        return asset.Url, asset.ImageRectOffset, asset.ImageRectSize
    end
    return "rbxassetid://0", Vector2.new(0,0), Vector2.new(48,48)
end

local function applyIcon(imgLabel, name)
    local url, offset, size = getIcon(name)
    imgLabel.Image = url
    imgLabel.ImageRectOffset = offset
    imgLabel.ImageRectSize = size
end

