local allTabs = {}
local activeTabKey = nil
local tabOrder = 0

local function makeTab(cfg)
    tabOrder += 1
    local key = tostring(tabOrder)

    local btn = Instance.new("TextButton", tabList)
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.ZIndex = 5
    btn.LayoutOrder = tabOrder
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local emo = Instance.new("TextLabel", btn)
    emo.Size = UDim2.new(0, 26, 1, 0)
    emo.Position = UDim2.new(0, 8, 0, 0)
    emo.BackgroundTransparency = 1
    emo.Text = cfg.Emoji or "◆"
    emo.TextSize = 14
    emo.Font = Enum.Font.GothamBold
    emo.TextColor3 = T.SubText
    emo.ZIndex = 6

    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, -36, 1, 0)
    lbl.Position = UDim2.new(0, 36, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = cfg.Title or "Tab"
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextColor3 = T.SubText
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 6

    local scroll = Instance.new("ScrollingFrame", content)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = T.Accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Visible = false
    scroll.ZIndex = 4
    local sl = Instance.new("UIListLayout", scroll)
    sl.SortOrder = Enum.SortOrder.LayoutOrder
    sl.Padding = UDim.new(0, 0)
    local sp = Instance.new("UIPadding", scroll)
    sp.PaddingLeft = UDim.new(0, 10)
    sp.PaddingRight = UDim.new(0, 14)
    sp.PaddingTop = UDim.new(0, 8)

    allTabs[key] = {btn=btn, scroll=scroll, emo=emo, lbl=lbl, title=cfg.Title or "Tab"}

    local function activate()
        for k, d in pairs(allTabs) do
            local on = k == key
            TweenService:Create(d.btn, TweenInfo.new(0.18), {
                BackgroundColor3     = on and T.Accent or Color3.fromRGB(0,0,0),
                BackgroundTransparency = on and 0 or 1,
            }):Play()
            TweenService:Create(d.lbl, TweenInfo.new(0.18), {
                TextColor3 = on and Color3.fromRGB(255,255,255) or T.SubText
            }):Play()
            TweenService:Create(d.emo, TweenInfo.new(0.18), {
                TextColor3 = on and Color3.fromRGB(255,255,255) or T.SubText
            }):Play()
            d.scroll.Visible = on
        end
        pageTitleLbl.Text = cfg.Title or ""
        activeTabKey = key
    end

    btn.MouseButton1Click:Connect(activate)
    if tabOrder == 1 then activate() end

    -- row counter
    local rowCount = 0

    local function makeRow(h)
        rowCount += 1
        local row = Instance.new("Frame", scroll)
        row.Size = UDim2.new(1, 0, 0, h)
        row.BackgroundColor3 = T.RowBg
        row.BorderSizePixel = 0
        row.ZIndex = 5
        row.LayoutOrder = rowCount * 10
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)
        local rs = Instance.new("UIStroke", row)
        rs.Color = T.Border
        rs.Thickness = 1
        local gap = Instance.new("Frame", scroll)
        gap.Size = UDim2.new(1, 0, 0, 5)
        gap.BackgroundTransparency = 1
        gap.LayoutOrder = rowCount * 10 + 1
        return row, rs
    end

    local tabObj = {}

    function tabObj:Section(sCfg)
        sCfg = sCfg or {}
        rowCount += 1
        local hdr = Instance.new("Frame", scroll)
        hdr.Size = UDim2.new(1, 0, 0, 26)
        hdr.BackgroundTransparency = 1
        hdr.ZIndex = 5
        hdr.LayoutOrder = rowCount * 10
        local hLbl = Instance.new("TextLabel", hdr)
        hLbl.Size = UDim2.new(1, 0, 1, 0)
        hLbl.BackgroundTransparency = 1
        hLbl.Text = (sCfg.Title or ""):upper()
        hLbl.Font = Enum.Font.GothamBold
        hLbl.TextSize = 9
        hLbl.LetterSpacing = 2
        hLbl.TextColor3 = T.SecLabel
        hLbl.TextXAlignment = Enum.TextXAlignment.Left
        hLbl.ZIndex = 6

        local sObj = {}

        function sObj:Toggle(cfg)
            local row, rs = makeRow(54)
            local nL = Instance.new("TextLabel", row)
            nL.Size = UDim2.new(1,-70,0,18)
            nL.Position = UDim2.new(0,14,0,10)
            nL.BackgroundTransparency = 1
            nL.Text = cfg.Title or ""
            nL.Font = Enum.Font.GothamBold
            nL.TextSize = 13
            nL.TextColor3 = T.Text
